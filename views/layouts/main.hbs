<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {{#if repo}}<meta name="repo-id" content="{{repo.id}}">{{/if}}
  <title>{{title}} — TestFlow</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <nav class="topnav">
    <div class="topnav-inner">
      <a href="/projects" class="brand">
        <span class="brand-icon">⬡</span>
        <span class="brand-name">TestFlow</span>
      </a>
      <div class="topnav-right">
        {{#if project}}
          <span class="nav-crumb">
            <a href="/projects">Projects</a>
            <span class="crumb-sep">/</span>
            <a href="/projects/{{project.slug}}">{{project.name}}</a>
            {{#if repo}}
              <span class="crumb-sep">/</span>
              <a href="/projects/{{project.slug}}/repos/{{repo.slug}}">{{repo.name}}</a>
            {{/if}}
          </span>
        {{/if}}
      </div>
    </div>
  </nav>

  <main class="main-content">
    {{{body}}}
  </main>

  <script src="/js/main.js"></script>
</body>
</html>
