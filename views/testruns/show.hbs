  <span style="font-size:0.82rem;color:var(--text-3)">Filter:</span>
  <button class="btn btn-sm run-filter active" data-filter="all">All</button>
  <button class="btn btn-sm run-filter" data-filter="pending" style="color:var(--text-3)">Pending</button>
