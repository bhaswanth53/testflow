              <button type="button" class="btn btn-ghost btn-sm edit-note-btn" style="font-size:0.78rem">Edit</button>
              <button type="button" class="btn btn-ghost btn-sm delete-note-btn" style="font-size:0.78rem;color:var(--red)"
                data-url="/projects/{{../../../project.slug}}/repos/{{../../../repo.slug}}/runs/{{../../../run.id}}/results/{{../../id}}/notes/{{id}}/delete">✕</button>
