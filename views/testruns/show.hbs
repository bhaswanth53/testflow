</div>

<script>
document.querySelectorAll('.run-filter').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.run-filter').forEach(b => b.classList.remove('active','btn-primary'));
    btn.classList.add('active','btn-primary');
    const f = btn.dataset.filter;
    document.querySelectorAll('.run-result-row').forEach(row => {
      row.style.display = (f === 'all' || row.dataset.status === f) ? '' : 'none';
    });
  });
});

document.querySelectorAll('.steps-raw').forEach(el => {
  const lines = el.textContent.split('\n').map(l => l.replace(/^\d+[\.\)]\s*/, '').trim()).filter(Boolean);
  if (lines.length > 1) {
    const ol = document.createElement('ol'); ol.className = 'steps-list';
    lines.forEach(l => { const li = document.createElement('li'); li.textContent = l; ol.appendChild(li); });
    el.replaceWith(ol);
  }
});

// ── Inline rich editor (paste fix: preventDefault is synchronous) ──
function initInlineEditor(wrap) {
  const toolbar = wrap.querySelector('.rich-editor-toolbar');
  const editor = wrap.querySelector('.rich-editor');
  const hidden = wrap.querySelector('input[name=content], input[type=hidden]');
  if (!toolbar || !editor) return;

  toolbar.addEventListener('mousedown', e => {
    e.preventDefault();
    const btn = e.target.closest('.toolbar-btn');
    if (!btn) return;
    const cmd = btn.dataset.cmd, val = btn.dataset.val;
    if (cmd === 'insertImage') triggerImageUpload(editor);
    else if (cmd === 'createLink') { const u = prompt('URL:'); if (u) document.execCommand('createLink', false, u); }
    else document.execCommand(cmd, false, val || null);
    editor.focus();
    if (hidden) hidden.value = editor.innerHTML;
  });

  editor.addEventListener('input', () => { if (hidden) hidden.value = editor.innerHTML; });

  editor.addEventListener('paste', e => {
    const items = e.clipboardData?.items;
    if (!items) return;
    for (const item of items) {
      if (item.type.startsWith('image/')) {
        e.preventDefault();
        e.stopPropagation();
        uploadImage(item.getAsFile()).then(url => {
          if (url) { editor.focus(); document.execCommand('insertImage', false, url); if (hidden) hidden.value = editor.innerHTML; }
        });
        return;
      }
    }
  });

  editor.addEventListener('drop', e => {
    const files = e.dataTransfer?.files; if (!files?.length) return;
    let handled = false;
    for (const f of files) {
      if (f.type.startsWith('image/')) {
        if (!handled) { e.preventDefault(); handled = true; }
        uploadImage(f).then(url => {
          if (url) { editor.focus(); document.execCommand('insertImage', false, url); if (hidden) hidden.value = editor.innerHTML; }
        });
      }
    }
  });
}

document.querySelectorAll('.add-note-form .rich-editor-wrap').forEach(initInlineEditor);

// ── Per-case note: submit ──
document.addEventListener('click', async e => {
  const submitBtn = e.target.closest('.add-note-submit');
  if (submitBtn) {
    const form = submitBtn.closest('.add-note-form');
    const editor = form.querySelector('.rich-editor');
    const hidden = form.querySelector('input[name=content]');
    const content = editor.innerHTML.trim();
    if (!content || content === '<br>') { showToast('Note is empty','error'); return; }
    try {
      const r = await fetch(form.dataset.url, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ content }) });
      const data = await r.json();
      if (data.ok) {
        const notesList = form.closest('.run-result-body').querySelector('.notes-list');
        const div = document.createElement('div');
        div.className = 'note-card'; div.dataset.noteId = data.note.id; div.style.marginBottom = '8px';
        div.innerHTML = `<div class="note-card-header"><span class="note-time">Just now</span><div style="display:flex;gap:4px"><button type="button" class="btn btn-ghost btn-sm edit-note-btn" style="font-size:0.78rem">Edit</button><button type="button" class="btn btn-ghost btn-sm delete-note-btn" style="font-size:0.78rem;color:var(--red)">✕</button></div></div><div class="note-content">${data.note.content}</div>`;
        notesList.appendChild(div);
        editor.innerHTML = ''; if (hidden) hidden.value = '';
        showToast('Note added','success');
      }
    } catch { showToast('Error saving note','error'); }
    return;
  }

  // Delete per-case note
  const delBtn = e.target.closest('.delete-note-btn');
  if (delBtn) {
    if (!confirm('Delete this note?')) return;
    const noteCard = delBtn.closest('.note-card');
    const noteId = noteCard?.dataset?.noteId;
    const addForm = noteCard?.closest('.run-result-body')?.querySelector('.add-note-form');
    const deleteUrl = delBtn.dataset.url || (addForm ? addForm.dataset.url + '/' + noteId + '/delete' : null);
    if (!deleteUrl) return;
    try {
      const r = await fetch(deleteUrl, { method:'POST' });
      const data = await r.json();
      if (data.ok) { noteCard.remove(); showToast('Note deleted'); }
    } catch {}
    return;
  }

  // Edit per-case note inline
  const editBtn = e.target.closest('.edit-note-btn');
  if (editBtn) {
    const noteCard = editBtn.closest('.note-card');
    const contentEl = noteCard.querySelector('.note-content');
    const noteId = noteCard.dataset.noteId;
    const addForm = noteCard.closest('.run-result-body')?.querySelector('.add-note-form');
    if (!addForm) return;
    const editUrl = addForm.dataset.url + '/' + noteId + '/edit';
    if (editBtn.textContent === 'Edit') {
      contentEl.contentEditable = 'true';
      contentEl.style.cssText = 'border:1px solid var(--accent);border-radius:var(--radius);padding:6px;outline:none';
      contentEl.focus(); editBtn.textContent = 'Save';
    } else {
      try {
        const r = await fetch(editUrl, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ content: contentEl.innerHTML }) });
        const data = await r.json();
        if (data.ok) { contentEl.contentEditable='false'; contentEl.style.cssText=''; editBtn.textContent='Edit'; showToast('Note updated','success'); }
      } catch { showToast('Error','error'); }
    }
    return;
  }
});

// ── Run-level notes ──
const runNoteEditorWrap = document.getElementById('run-note-editor-wrap');
if (runNoteEditorWrap) {
  const editor = document.getElementById('run-note-editor');
  const hidden = document.getElementById('run-note-content');
  const toolbar = runNoteEditorWrap.querySelector('.rich-editor-toolbar');

  toolbar?.addEventListener('mousedown', e => {
    e.preventDefault();
    const btn = e.target.closest('.toolbar-btn');
    if (!btn) return;
    const cmd = btn.dataset.cmd, val = btn.dataset.val;
    if (cmd === 'insertImage') triggerImageUpload(editor);
    else if (cmd === 'createLink') { const u = prompt('URL:'); if (u) document.execCommand('createLink', false, u); }
    else document.execCommand(cmd, false, val || null);
    editor.focus(); hidden.value = editor.innerHTML;
  });

  editor?.addEventListener('input', () => { hidden.value = editor.innerHTML; });

  editor?.addEventListener('paste', e => {
    const items = e.clipboardData?.items; if (!items) return;
    for (const item of items) {
      if (item.type.startsWith('image/')) {
        e.preventDefault(); e.stopPropagation();
        uploadImage(item.getAsFile()).then(url => {
          if (url) { editor.focus(); document.execCommand('insertImage', false, url); hidden.value = editor.innerHTML; }
        });
        return;
      }
    }
  });

  editor?.addEventListener('drop', e => {
    const files = e.dataTransfer?.files; if (!files?.length) return;
    let handled = false;
    for (const f of files) {
      if (f.type.startsWith('image/')) {
        if (!handled) { e.preventDefault(); handled = true; }
        uploadImage(f).then(url => {
          if (url) { editor.focus(); document.execCommand('insertImage', false, url); hidden.value = editor.innerHTML; }
        });
      }
    }
  });

  document.getElementById('run-note-submit')?.addEventListener('click', async () => {
    const content = editor.innerHTML.trim();
    if (!content || content === '<br>') { showToast('Note is empty','error'); return; }
    const form = document.querySelector('.run-note-add-form');
    try {
      const r = await fetch(form.dataset.url, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ content }) });
      const data = await r.json();
      if (data.ok) {
        const list = document.getElementById('run-notes-list');
        const div = document.createElement('div');
        div.className = 'note-card'; div.dataset.runNoteId = data.note.id; div.style.marginBottom = '10px';
        div.innerHTML = `<div class="note-card-header"><span class="note-time">Just now</span><div style="display:flex;gap:4px"><button type="button" class="btn btn-ghost btn-sm run-note-edit-btn" style="font-size:0.78rem">Edit</button><button type="button" class="btn btn-ghost btn-sm run-note-delete-btn" style="font-size:0.78rem;color:var(--red)" data-url="${form.dataset.url}/${data.note.id}/delete">✕</button></div></div><div class="note-content">${data.note.content}</div>`;
        list.appendChild(div);
        editor.innerHTML = ''; hidden.value = '';
        showToast('Note added','success');
      }
    } catch { showToast('Error','error'); }
  });
}

document.addEventListener('click', async e => {
  const delBtn = e.target.closest('.run-note-delete-btn');
  if (delBtn) {
    if (!confirm('Delete this note?')) return;
    try {
      const r = await fetch(delBtn.dataset.url, { method:'POST' });
      const data = await r.json();
      if (data.ok) { delBtn.closest('.note-card')?.remove(); showToast('Note deleted'); }
    } catch {}
    return;
  }
  const editBtn = e.target.closest('.run-note-edit-btn');
  if (editBtn) {
    const noteCard = editBtn.closest('.note-card');
    const contentEl = noteCard.querySelector('.note-content');
    const noteId = noteCard.dataset.runNoteId;
    const form = document.querySelector('.run-note-add-form');
    const editUrl = form.dataset.url + '/' + noteId + '/edit';
    if (editBtn.textContent === 'Edit') {
      contentEl.contentEditable = 'true';
      contentEl.style.cssText = 'border:1px solid var(--accent);border-radius:var(--radius);padding:6px;outline:none';
      contentEl.focus(); editBtn.textContent = 'Save';
    } else {
      try {
        const r = await fetch(editUrl, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ content: contentEl.innerHTML }) });
        const data = await r.json();
        if (data.ok) { contentEl.contentEditable='false'; contentEl.style.cssText=''; editBtn.textContent='Edit'; showToast('Updated','success'); }
      } catch { showToast('Error','error'); }
    }
  }
});
</script>