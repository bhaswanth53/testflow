<div class="page-title-row">
  <div>
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
      <span class="status-badge {{run.status}}">{{statusLabel run.status}}</span>
      {{#if run.plan_name}}<span class="badge badge-blue">{{run.plan_name}}</span>{{/if}}
      <span style="font-size:0.82rem;color:var(--text-3)">{{formatDate run.created_at}}</span>
    </div>
    <h1>{{run.name}}</h1>
    {{#if run.description}}<p style="color:var(--text-2);margin-top:4px">{{run.description}}</p>{{/if}}
  </div>
  <div class="btn-group">
    <a href="/projects/{{project.slug}}/repos/{{repo.slug}}/runs/{{run.id}}/pdf" target="_blank" class="btn btn-secondary">⬇ Export PDF</a>
    {{#if (eq run.status 'in_progress')}}
    <form action="/projects/{{project.slug}}/repos/{{repo.slug}}/runs/{{run.id}}/status" method="POST" style="display:inline">
      <input type="hidden" name="status" value="completed">
      <button type="submit" class="btn btn-primary" data-confirm="Mark this run as completed?">✔ Complete Run</button>
    </form>
    <form action="/projects/{{project.slug}}/repos/{{repo.slug}}/runs/{{run.id}}/status" method="POST" style="display:inline">
      <input type="hidden" name="status" value="aborted">
      <button type="submit" class="btn btn-secondary" data-confirm="Abort this run?">✕ Abort</button>
    </form>
    {{else}}
    <form action="/projects/{{project.slug}}/repos/{{repo.slug}}/runs/{{run.id}}/status" method="POST" style="display:inline">
      <input type="hidden" name="status" value="in_progress">
      <button type="submit" class="btn btn-secondary">↩ Reopen</button>
    </form>
    {{/if}}
    <form action="/projects/{{project.slug}}/repos/{{repo.slug}}/runs/{{run.id}}/delete" method="POST" style="display:inline">
      <button type="submit" class="btn btn-danger" data-confirm="Delete this run and all results?">Delete</button>
    </form>
  </div>
</div>

{{#if (or run.test_url (or run.environment run.browser))}}
<div class="card" style="margin-bottom:16px">
  <div class="card-body" style="display:flex;gap:24px;flex-wrap:wrap;align-items:center;padding:12px 20px">
    {{#if run.environment}}
    <div style="display:flex;align-items:center;gap:7px;font-size:0.875rem">
      <span style="color:var(--text-3)">🖥</span>
      <span style="font-weight:500;color:var(--text-2)">Environment:</span>
      <span>{{run.environment}}</span>
    </div>
    {{/if}}
    {{#if run.browser}}
    <div style="display:flex;align-items:center;gap:7px;font-size:0.875rem">
      <span style="color:var(--text-3)">🌐</span>
      <span style="font-weight:500;color:var(--text-2)">Browser:</span>
      <span>{{run.browser}}</span>
    </div>
    {{/if}}
    {{#if run.test_url}}
    <div style="display:flex;align-items:center;gap:7px;font-size:0.875rem">
      <span style="color:var(--text-3)">🔗</span>
      <span style="font-weight:500;color:var(--text-2)">URL:</span>
      <a href="{{run.test_url}}" target="_blank">{{run.test_url}}</a>
    </div>
    {{/if}}
  </div>
</div>
{{/if}}

<div class="card" style="margin-bottom:20px">
  <div class="card-body">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(100px,1fr));gap:16px;margin-bottom:14px">
      <div style="text-align:center">
        <div style="font-size:1.6rem;font-weight:600">{{statusCounts.total}}</div>
        <div style="font-size:0.75rem;color:var(--text-3);text-transform:uppercase;letter-spacing:0.04em">Total</div>
      </div>
      <div style="text-align:center">
        <div style="font-size:1.6rem;font-weight:600;color:var(--green)" class="count-passed">{{statusCounts.passed}}</div>
        <div style="font-size:0.75rem;color:var(--green);text-transform:uppercase;letter-spacing:0.04em">Passed</div>
      </div>
      <div style="text-align:center">
        <div style="font-size:1.6rem;font-weight:600;color:var(--red)" class="count-failed">{{statusCounts.failed}}</div>
        <div style="font-size:0.75rem;color:var(--red);text-transform:uppercase;letter-spacing:0.04em">Failed</div>
      </div>
      <div style="text-align:center">
        <div style="font-size:1.6rem;font-weight:600;color:var(--purple)" class="count-blocked">{{statusCounts.blocked}}</div>
        <div style="font-size:0.75rem;color:var(--purple);text-transform:uppercase;letter-spacing:0.04em">Blocked</div>
      </div>
      <div style="text-align:center">
        <div style="font-size:1.6rem;font-weight:600;color:var(--text-3)" class="count-skipped">{{statusCounts.skipped}}</div>
        <div style="font-size:0.75rem;color:var(--text-3);text-transform:uppercase;letter-spacing:0.04em">Skipped</div>
      </div>
      <div style="text-align:center">
        <div style="font-size:1.6rem;font-weight:600;color:var(--text-3)" class="count-pending">{{statusCounts.pending}}</div>
        <div style="font-size:0.75rem;color:var(--text-3);text-transform:uppercase;letter-spacing:0.04em">Pending</div>
      </div>
    </div>
    <div class="progress-stacked">
      <div class="seg seg-passed" style="width:{{pct statusCounts.passed statusCounts.total}}%"></div>
      <div class="seg seg-failed" style="width:{{pct statusCounts.failed statusCounts.total}}%"></div>
      <div class="seg seg-blocked" style="width:{{pct statusCounts.blocked statusCounts.total}}%"></div>
      <div class="seg seg-skipped" style="width:{{pct statusCounts.skipped statusCounts.total}}%"></div>
      <div class="seg seg-pending" style="width:{{pct statusCounts.pending statusCounts.total}}%"></div>
    </div>
    {{#if (eq run.status 'completed')}}
    <div style="margin-top:10px;font-size:0.82rem;color:var(--text-3)">
      ✔ Completed {{formatDateTime run.completed_at}}
      — Pass rate: <strong style="color:var(--green)">{{pct statusCounts.passed statusCounts.total}}%</strong>
    </div>
    {{/if}}
  </div>
</div>

<!-- Run-level Notes -->
<div class="card" style="margin-bottom:20px">
  <div class="card-header">
    <h2>📝 Run Notes</h2>
    <span style="font-size:0.8rem;color:var(--text-3)">General observations, suggestions, and thoughts about this run</span>
  </div>
  <div class="card-body">
    <div id="run-notes-list">
      {{#each runNotes}}
      <div class="note-card" data-run-note-id="{{id}}" style="margin-bottom:10px">
        <div class="note-card-header">
          <span class="note-time">{{formatDateTime created_at}}</span>
          {{#if (eq ../run.status 'in_progress')}}
