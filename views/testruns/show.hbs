      {{#if (eq ../run.status 'in_progress')}}
      <div style="margin-top:10px">
        <div style="font-size:0.8rem;color:var(--text-3);margin-bottom:6px">Add a note — supports rich text, images (paste or drag)</div>
        <div class="add-note-form"
          data-url="/projects/{{../project.slug}}/repos/{{../repo.slug}}/runs/{{../run.id}}/results/{{id}}/notes">
          <div class="rich-editor-wrap">
            <div class="rich-editor-toolbar">
              <button type="button" class="toolbar-btn" data-cmd="bold"><b>B</b></button>
              <button type="button" class="toolbar-btn" data-cmd="italic"><i>I</i></button>
              <button type="button" class="toolbar-btn" data-cmd="underline"><u>U</u></button>
              <button type="button" class="toolbar-btn" data-cmd="strikeThrough"><s>S</s></button>
              <span class="toolbar-sep"></span>
              <button type="button" class="toolbar-btn" data-cmd="insertUnorderedList">• List</button>
              <button type="button" class="toolbar-btn" data-cmd="insertOrderedList">1. List</button>
              <span class="toolbar-sep"></span>
              <button type="button" class="toolbar-btn" data-cmd="formatBlock" data-val="blockquote">❝</button>
              <button type="button" class="toolbar-btn" data-cmd="formatBlock" data-val="pre">{ }</button>
              <span class="toolbar-sep"></span>
              <button type="button" class="toolbar-btn" data-cmd="insertImage">📷 Image</button>
              <button type="button" class="toolbar-btn" data-cmd="createLink">🔗 Link</button>
