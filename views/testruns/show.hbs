            <button type="button" class="btn btn-ghost btn-sm run-note-edit-btn" style="font-size:0.78rem">Edit</button>
            <button type="button" class="btn btn-ghost btn-sm run-note-delete-btn" style="font-size:0.78rem;color:var(--red)"
              data-url="/projects/{{../project.slug}}/repos/{{../repo.slug}}/runs/{{../run.id}}/run-notes/{{id}}/delete">✕</button>
          </div>
          {{/if}}
        </div>
        <div class="note-content">{{{content}}}</div>
      </div>
      {{/each}}
    </div>
    {{#if (eq run.status 'in_progress')}}
